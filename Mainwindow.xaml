        /// <summary>
        /// Deletes a merchant account. Per the marking sheet: "delete merchant account" (1 mark) plus
        /// "Cascaded deletes/updates (e.g. removing a merchant and their orders)" (2 marks).
        ///
        /// This runs a real SQL DELETE (hard delete) against the ipos_sa database, inside a
        /// single transaction. Rows are removed in foreign-key order from:
        ///   payments → invoices → monthly_discount_tracker → orders (cascades order_items)
        ///   → merchants → users (the merchant's login).
        /// If any audit_log rows still reference the user, the user row is kept to preserve
        /// the audit history; the merchant row is gone either way.
        /// </summary>
        private async void Merchant_Delete(object sender, RoutedEventArgs e)
        {
            if (((Button)sender).Tag is not MerchantDTO row) return;

            var confirmation =
                $"DELETE merchant '{row.CompanyName}' (ID {row.MerchantId}) from the database?\n\n" +
                "This is a CASCADE hard-delete — it runs a real SQL DELETE against the\n" +
                "ipos_sa database and removes, in a single transaction:\n\n" +
                "  • all payments for this merchant\n" +
                "  • all invoices for this merchant\n" +
                "  • the monthly discount tracker rows\n" +
                "  • all orders (and their order items) for this merchant\n" +
                "  • the merchant row itself\n" +
                "  • the merchant's login (user row), if not needed by audit log\n\n" +
                "This cannot be undone. Continue?";

            if (MessageBox.Show(confirmation, "Confirm Merchant Deletion",
                    MessageBoxButton.YesNo, MessageBoxImage.Warning) != MessageBoxResult.Yes) return;

            try
            {
                var summary = await DatabaseService.DeleteMerchantCascadeAsync(row.MerchantId);
                MessageBox.Show(
                    $"Merchant '{row.CompanyName}' deleted from the database.\n\n{summary}",
                    "Merchant Deleted", MessageBoxButton.OK, MessageBoxImage.Information);
                await LoadMerchantsAsync();
            }
            catch (Exception ex)
            {
                MessageBox.Show(
                    "Delete failed — the transaction was rolled back so no rows were changed.\n\n" +
                    "Error: " + ex.Message,
                    "Delete Error", MessageBoxButton.OK, MessageBoxImage.Error);
            }
        }


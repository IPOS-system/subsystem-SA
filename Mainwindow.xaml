        private async void Application_Reject(object sender, RoutedEventArgs e)
        {
            if (((Button)sender).Tag is not CommercialApplicationDTO app) return;

            var reason = PromptForReason(
                "Reason for rejection (optional, will be included in the email):",
                "Reject Application");

            var confirmation =
                $"Reject application #{app.ApplicationId} from '{app.CompanyName}'?\n\n" +
                $"A rejection email will be sent via SMTP to: {app.Email}";

            if (MessageBox.Show(confirmation, "Confirm Rejection",
                    MessageBoxButton.YesNo, MessageBoxImage.Warning) != MessageBoxResult.Yes) return;

            try
            {
                await Instance.HttpService.PutRejectApplicationAsync(app.ApplicationId, reason);
                MessageBox.Show(
                    $"Application rejected. Notification email sent to {app.Email}.",
                    "Rejected", MessageBoxButton.OK, MessageBoxImage.Information);
                await LoadApplicationsAsync();
            }
            catch (Exception ex) { MessageBox.Show("Error: " + ex.Message); }
        }

        // Small WPF-native prompt used for rejection reason (avoids Microsoft.VisualBasic dep)
        private static string? PromptForReason(string message, string title)
        {
            var dlg = new Window
            {
                Title = title,
                Width = 460,
                Height = 220,
                WindowStartupLocation = WindowStartupLocation.CenterOwner,
                Owner = Application.Current?.MainWindow,
                ResizeMode = ResizeMode.NoResize
            };
            var grid = new Grid { Margin = new Thickness(16) };
            grid.RowDefinitions.Add(new RowDefinition { Height = GridLength.Auto });
            grid.RowDefinitions.Add(new RowDefinition { Height = new GridLength(1, GridUnitType.Star) });
            grid.RowDefinitions.Add(new RowDefinition { Height = GridLength.Auto });

            var label = new TextBlock { Text = message, TextWrapping = TextWrapping.Wrap, Margin = new Thickness(0, 0, 0, 8) };
            Grid.SetRow(label, 0);

            var tb = new TextBox { AcceptsReturn = true, TextWrapping = TextWrapping.Wrap, VerticalScrollBarVisibility = ScrollBarVisibility.Auto };
            Grid.SetRow(tb, 1);

            var btns = new StackPanel { Orientation = Orientation.Horizontal, HorizontalAlignment = HorizontalAlignment.Right, Margin = new Thickness(0, 8, 0, 0) };
            var okBtn = new Button { Content = "OK", Width = 80, Margin = new Thickness(0, 0, 8, 0), IsDefault = true };
            var cancelBtn = new Button { Content = "Cancel", Width = 80, IsCancel = true };
            string? result = null;
            okBtn.Click += (_, __) => { result = tb.Text; dlg.DialogResult = true; };
            btns.Children.Add(okBtn);
            btns.Children.Add(cancelBtn);
            Grid.SetRow(btns, 2);

            grid.Children.Add(label);
            grid.Children.Add(tb);
            grid.Children.Add(btns);
            dlg.Content = grid;
            tb.Focus();
            return dlg.ShowDialog() == true ? result : null;
        }
    }


<Window
    x:Class="GOATflow.Concept2"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:GOATflow"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Concept2"
    Width="635"
    Height="400"
    AllowsTransparency="True"
    Background="Transparent"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">

    <Border
        MouseLeftButtonDown="Border_MouseLeftButtonDown"
        Margin="0"
        BorderBrush="#181926"
        BorderThickness="1"
        CornerRadius="10">
        <Border.Background>
            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Color="#002022" />
                <GradientStop Offset="1" Color="#348688" />
            </LinearGradientBrush>
        </Border.Background>

        <Grid>

            <Border
                Background="#181926"
                CornerRadius="7 0 0 7" HorizontalAlignment="Left" Width="308">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="100"
                        Direction="0"
                        Opacity="1"
                        ShadowDepth="10"
                        Color="#002022" />
                </Border.Effect>
                <Grid>

                    <Label
                        Margin="35,71,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Content="Welcome Back."
                        FontFamily="/GOATflow;component/Assets/Fonts/Poppins/#Poppins Semibold"
                        FontSize="16"
                        Foreground="#7c7c84" />
                    <Label
                        Margin="35,101,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Content="Please enter your credentials&#x0a;below to continue..."
                        FontFamily="/GOATflow;component/Assets/Fonts/Poppins/#Poppins Light"
                        FontSize="13"
                        Foreground="#7c7c84"
                        Opacity=".5" />
                    <TextBox
                        x:Name="UserBox"
                        Height="45"
                        Margin="35,168,34,185"
                        Background="Transparent"
                        Style="{StaticResource UsernameTextBoxStyle}"
                        Text="" />
                    <TextBox
                        x:Name="PasswordBox"
                        Height="45"
                        Margin="35,225,34,128"
                        Background="Transparent"
                        Style="{StaticResource PasswordTextBoxStyle}"
                            Text="{Binding Text, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /> 
                    <Button
                        x:Name="LoginButton"
                        Height="32"
                        Margin="35,309,34,0"
                        VerticalAlignment="Top"
                        Background="#348688"
                        BorderBrush="{x:Null}"
                        Click="ButtonHandler"
                        Style="{DynamicResource TealButtonStyle}">

                        <TextBlock
                            Foreground="#24273a"
                            Text="Log In" />
                    </Button>
                    <Label
                        Margin="161,270,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Content="Trouble logging in?"
                        FontFamily="/GOATflow;component/Assets/Fonts/Poppins/#Poppins Semibold"
                        FontSize="11"
                        Foreground="#348688"
                        Opacity="1" />
                </Grid>
            </Border>

            <Label
                Margin="8,7,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Content="GOATflow"
                FontFamily="/GOATflow;component/Assets/Fonts/Poppins/#Poppins Semibold"
                FontSize="12"
                Foreground="White"
                Opacity=".1" />
            <StackPanel
                Margin="0,0,0,354"
                HorizontalAlignment="Right"
                Orientation="Horizontal">

                <Button
                    x:Name="Minimize"
                    Width="45"
                    Height="45"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="ButtonHandler"
                    Content="&#xE921;"
                    FontFamily="Segoe MDL2 Assets"
                    FontSize="10"
                    Foreground="#7c7c84">

                    <Button.ToolTip>Minimize</Button.ToolTip>

                </Button>

                <Button
                    x:Name="Exit"
                    Width="45"
                    Height="45"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="ButtonHandler"
                    Content="&#xE8BB;"
                    FontFamily="Segoe MDL2 Assets"
                    FontSize="10"
                    Foreground="#7c7c84">

                    <Button.ToolTip>Exit</Button.ToolTip>
                </Button>

            </StackPanel>

        </Grid>
    </Border>
</Window>

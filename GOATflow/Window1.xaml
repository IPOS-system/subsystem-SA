        <Button Height="32" Margin="25,194,715,0" VerticalAlignment="Top" HorizontalContentAlignment="Left"
                Background="#348688" BorderBrush="{x:Null}" Click="ButtonHandler"
                Style="{DynamicResource TransparentButtonStyle}" Tag="2">
            <Grid>
                <Path Width="14" Height="13" Margin="10,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center"
                      Data="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z"
                      Stretch="Fill" Stroke="White" StrokeThickness="1.5" />
                <TextBlock Margin="35,0,0,0" VerticalAlignment="Center" Foreground="White" Text="Basket" />
            </Grid>
        </Button>

        <Button Height="32" Margin="25,240,715,0" VerticalAlignment="Top" HorizontalContentAlignment="Left"
                Background="#348688" BorderBrush="{x:Null}" Click="ButtonHandler"
                Style="{DynamicResource TransparentButtonStyle}" Tag="3">
            <Grid>
                <Path Width="12" Height="13" Margin="12,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center"
                      Data="M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 0 1 0 3.75H5.625a1.875 1.875 0 0 1 0-3.75Z"
                      Stretch="Fill" Stroke="White" StrokeThickness="1.5" />
                <TextBlock Margin="36,0,0,0" VerticalAlignment="Center" Foreground="White" Text="My Orders" />
            </Grid>
        </Button>

        <Button Height="32" Margin="25,287,715,0" VerticalAlignment="Top" HorizontalContentAlignment="Left"
                Background="#348688" BorderBrush="{x:Null}" Click="ButtonHandler"
                Style="{DynamicResource TransparentButtonStyle}" Tag="4">
            <Grid>
                <Path Width="12" Height="13" Margin="12,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center"
                      Data="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z"
                      Stretch="Fill" Stroke="White" StrokeThickness="1.5" />
                <TextBlock Margin="36,0,0,0" VerticalAlignment="Center" Foreground="White" Text="My Balance" />
            </Grid>
        </Button>

        <!-- Reports nav button (kept from original, now Tag="5" placeholder) -->
        <Button Height="32" Margin="25,334,715,0" VerticalAlignment="Top" HorizontalContentAlignment="Left"
                Background="#348688" BorderBrush="{x:Null}" Click="ButtonHandler"
                Style="{DynamicResource TransparentButtonStyle}" Tag="5">
            <Grid>
                <Path Width="12" Height="13" Margin="12,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center"
                      Data="M3.75 6.75h16.5M3.75 12H12m-8.25 5.25h16.5"
                      Stretch="Fill" Stroke="White" StrokeThickness="1.5" />
                <TextBlock Margin="36,0,0,0" VerticalAlignment="Center" Foreground="White" Text="Reports" />
            </Grid>
        </Button>

        <!-- Log Out -->
        <Button Height="32" Margin="25,477,715,0" VerticalAlignment="Top" HorizontalContentAlignment="Left"
                Background="#348688" BorderBrush="{x:Null}" Click="ButtonHandler"
                Style="{DynamicResource TealButtonStyle}">
            <Grid>
                <Path Width="12" Height="13" Margin="12,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center"
                      Data="M8.25 9V5.25A2.25 2.25 0 0 1 10.5 3h6a2.25 2.25 0 0 1 2.25 2.25v13.5A2.25 2.25 0 0 1 16.5 21h-6a2.25 2.25 0 0 1-2.25-2.25V15m-3 0-3-3m0 0 3-3m-3 3H15"
                      Stretch="Fill" Stroke="#181926" StrokeThickness="1.5" />
                <TextBlock Margin="36,0,0,0" VerticalAlignment="Center" Foreground="#181926" Text="Log Out" />
            </Grid>
        </Button>

        <!-- Window chrome controls -->
        <StackPanel Margin="0,0,3,494" HorizontalAlignment="Right" Orientation="Horizontal">
            <Button x:Name="Minimize" Width="45" Height="45" VerticalAlignment="Center"
                    Background="Transparent" BorderThickness="0" Click="ButtonHandler"
                    Content="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#7c7c84">
                <Button.ToolTip>Minimize</Button.ToolTip>
            </Button>
            <Button x:Name="Maximize" Width="45" Height="45" VerticalAlignment="Center"
                    Background="Transparent" BorderThickness="0" Click="ButtonHandler"
                    Content="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#7c7c84">
                <Button.ToolTip>Maximize</Button.ToolTip>
            </Button>
            <Button x:Name="Exit" Width="45" Height="45" VerticalAlignment="Center"
                    Background="Transparent" BorderThickness="0" Click="ButtonHandler"
                    Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#7c7c84">
                <Button.ToolTip>Exit</Button.ToolTip>
            </Button>
        </StackPanel>

        <Border Height="1" Margin="0,48,0,485" Background="#292A37" />

        <!-- Notification bell -->
        <Grid Width="25" Height="26" Margin="0,15,165,0" HorizontalAlignment="Right" VerticalAlignment="Top">
            <Ellipse Width="25" Height="25" HorizontalAlignment="Right" VerticalAlignment="Top" Fill="#FF20242B" />
            <Path Width="11" Height="12" Margin="7,6,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"
                  Data="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0"
                  Stretch="Fill" Stroke="#FF747474" />
        </Grid>

        <Label Margin="60,13,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"
               Content="GoatFlow" FontFamily="/GOATflow;component/Assets/Fonts/Poppins/#Poppins"
               FontSize="15" Foreground="White" Opacity=".8" />

        <!-- Breadcrumb — update from code-behind -->
        <Label x:Name="BreadcrumbSectionLabel"
               Margin="225,13,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"
               Content="Merchant >" FontFamily="/GOATflow;component/Assets/Fonts/Poppins/#Poppins"
               FontSize="15" Foreground="White" Opacity=".3" />
        <Label x:Name="BreadcrumbPageLabel"
               Margin="314,13,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"
               Content="Dashboard" FontFamily="/GOATflow;component/Assets/Fonts/Poppins/#Poppins"
               FontSize="15" Foreground="White" Opacity=".8" />
    </Grid>
</Window>

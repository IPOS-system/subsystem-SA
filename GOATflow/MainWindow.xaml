<Window
    x:Class="GOATflow.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="GOATflow"
    Width="1100"
    Height="700"
    WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="185" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  ═══ SIDEBAR ═══  -->
        <StackPanel Grid.Column="0" Background="#2D2D2D">
            <TextBlock
                Margin="12,16,12,8"
                FontSize="18"
                FontWeight="Bold"
                Foreground="White"
                Text="GOATflow" />
            <TextBlock
                x:Name="UserLabel"
                Margin="12,0,12,12"
                FontSize="12"
                Foreground="#AAAAAA"
                TextWrapping="Wrap" />

            <!--  Payment reminder (merchant only)  -->
            <Border
                x:Name="PaymentReminderBanner"
                Margin="8,0,8,8"
                Padding="8,6"
                Background="#8B6914"
                CornerRadius="3"
                Visibility="Collapsed">
                <TextBlock
                    FontSize="11"
                    Foreground="White"
                    Text="⚠ Payment overdue. Please settle your balance."
                    TextWrapping="Wrap" />
            </Border>

            <!--  Nav buttons — all Collapsed by default, shown per role  -->
            <Button
                x:Name="NavAccountInfo"
                Click="NavClick"
                Content="Account Info"
                Style="{StaticResource NavBtn}"
                Visibility="Collapsed" />
            <Button
                x:Name="NavCatalogue"
                Click="NavClick"
                Content="Browse Catalogue"
                Style="{StaticResource NavBtn}"
                Visibility="Collapsed" />
            <Button
                x:Name="NavMyOrders"
                Click="NavClick"
                Content="My Orders"
                Style="{StaticResource NavBtn}"
                Visibility="Collapsed" />
            <Button
                x:Name="NavMyBalance"
                Click="NavClick"
                Content="My Balance"
                Style="{StaticResource NavBtn}"
                Visibility="Collapsed" />
            <Button
                x:Name="NavManageAccounts"
                Click="NavClick"
                Content="Manage Accounts"
                Style="{StaticResource NavBtn}"
                Visibility="Collapsed" />
            <Button
                x:Name="NavCatalogueMgmt"
                Click="NavClick"
                Content="Catalogue / Stock"
                Style="{StaticResource NavBtn}"
                Visibility="Collapsed" />
            <Button
                x:Name="NavOrders"
                Click="NavClick"
                Content="Orders Management"
                Style="{StaticResource NavBtn}"
                Visibility="Collapsed" />
            <Button
                x:Name="NavDiscountPlans"
                Click="NavClick"
                Content="Discount Plans"
                Style="{StaticResource NavBtn}"
                Visibility="Collapsed" />
            <Button
                x:Name="NavRecordPayment"
                Click="NavClick"
                Content="Record Payment"
                Style="{StaticResource NavBtn}"
                Visibility="Collapsed" />
            <Button
                x:Name="NavReports"
                Click="NavClick"
                Content="Reports"
                Style="{StaticResource NavBtn}"
                Visibility="Collapsed" />
            <Button
                x:Name="NavAuditLog"
                Click="NavClick"
                Content="Audit Log"
                Style="{StaticResource NavBtn}"
                Visibility="Collapsed" />

            <!--  Notifications (admin/manager)  -->
            <Border
                x:Name="NotifPanel"
                Margin="8,12,8,0"
                Padding="8"
                Background="#3A3A3A"
                CornerRadius="3"
                Visibility="Collapsed">
                <StackPanel>
                    <TextBlock
                        FontSize="12"
                        FontWeight="Bold"
                        Foreground="#CCCCCC"
                        Text="Notifications" />
                    <TextBlock
                        x:Name="NotifText"
                        Margin="0,4,0,0"
                        FontSize="11"
                        Foreground="#FF7070"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Button
                x:Name="NavLogout"
                Margin="0,20,0,0"
                Click="NavClick"
                Content="Logout"
                Foreground="#FF7070"
                Style="{StaticResource NavBtn}" />
        </StackPanel>

        <!--  ═══ CONTENT AREA ═══  -->
        <Border Grid.Column="1" Background="#F5F5F5">
            <Grid>

                <!--  ══ ACCOUNT INFO ══  -->
                <ScrollViewer
                    x:Name="PanelAccountInfo"
                    Margin="20"
                    Visibility="Collapsed">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                            <TextBlock
                                FontSize="20"
                                FontWeight="Bold"
                                Text="Account Info" />
                            <Button
                                Margin="16,0,0,0"
                                Click="AccountInfo_Refresh"
                                Content="Refresh" />
                        </StackPanel>
                        <TextBox
                            x:Name="AccountInfoBox"
                            Height="300"
                            Padding="8"
                            AcceptsReturn="True"
                            FontFamily="Consolas"
                            FontSize="13"
                            IsReadOnly="True"
                            TextWrapping="Wrap"
                            VerticalScrollBarVisibility="Auto" />
                    </StackPanel>
                </ScrollViewer>

                <!--  ══ BROWSE CATALOGUE ══  -->
                <Grid
                    x:Name="PanelCatalogue"
                    Margin="20"
                    Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        Margin="0,0,0,12"
                        FontSize="20"
                        FontWeight="Bold"
                        Text="Browse Catalogue" />
                    <StackPanel
                        Grid.Row="1"
                        Margin="0,0,0,8"
                        Orientation="Horizontal">
                        <TextBox
                            x:Name="CatalogueSearch"
                            Width="240"
                            Margin="0,0,6,0"
                            VerticalContentAlignment="Center" />
                        <Button
                            Margin="0,0,4,0"
                            Click="Catalogue_Search"
                            Content="Search" />
                        <Button Click="Catalogue_Clear" Content="Clear" />
                    </StackPanel>
                    <DataGrid
                        x:Name="CatalogueGrid"
                        Grid.Row="2"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Width="110"
                                Binding="{Binding ProductId}"
                                Header="Code" />
                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding Description}"
                                Header="Description" />
                            <DataGridTextColumn
                                Width="90"
                                Binding="{Binding PackageType}"
                                Header="Pack Type" />
                            <DataGridTextColumn
                                Width="60"
                                Binding="{Binding Unit}"
                                Header="Unit" />
                            <DataGridTextColumn
                                Width="85"
                                Binding="{Binding UnitPrice, StringFormat=£\{0:N2\}}"
                                Header="Unit Price" />
                            <DataGridTextColumn
                                Width="70"
                                Binding="{Binding Availability}"
                                Header="In Stock" />
                            <DataGridTemplateColumn Width="110" Header="Action">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button
                                            Padding="4,2"
                                            Click="Catalogue_AddToBasket"
                                            Content="Add to Basket"
                                            FontSize="10"
                                            Tag="{Binding}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Button
                        Grid.Row="3"
                        Margin="0,8,0,0"
                        HorizontalAlignment="Right"
                        Click="NavToBasket"
                        Content="View Basket / Place Order"
                        FontWeight="Bold" />
                </Grid>

                <!--  ══ BASKET / PLACE ORDER ══  -->
                <Grid
                    x:Name="PanelBasket"
                    Margin="20"
                    Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel
                        Grid.Row="0"
                        Margin="0,0,0,12"
                        Orientation="Horizontal">
                        <TextBlock
                            FontSize="20"
                            FontWeight="Bold"
                            Text="Place Order" />
                        <Button
                            x:Name="BackToCatalogue"
                            Margin="16,0,0,0"
                            Click="NavClick"
                            Content="← Back to Catalogue" />
                    </StackPanel>
                    <DataGrid
                        x:Name="BasketGrid"
                        Grid.Row="1"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        IsReadOnly="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Width="110"
                                Binding="{Binding ProductId}"
                                Header="Code"
                                IsReadOnly="True" />
                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding Description}"
                                Header="Description"
                                IsReadOnly="True" />
                            <DataGridTextColumn
                                Width="85"
                                Binding="{Binding UnitPrice, StringFormat=£\{0:N2\}}"
                                Header="Unit Price"
                                IsReadOnly="True" />
                            <DataGridTextColumn
                                Width="55"
                                Binding="{Binding Quantity}"
                                Header="Qty" />
                            <DataGridTextColumn
                                Width="90"
                                Binding="{Binding LineTotal, StringFormat=£\{0:N2\}}"
                                Header="Line Total"
                                IsReadOnly="True" />
                            <DataGridTemplateColumn Width="55" Header="">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button
                                            Click="Basket_Remove"
                                            Content="✕"
                                            FontSize="11"
                                            Tag="{Binding}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <!--  Order summary  -->
                    <Border
                        Grid.Row="2"
                        Margin="0,8,0,0"
                        Padding="12"
                        Background="White"
                        BorderBrush="#CCCCCC"
                        BorderThickness="1"
                        CornerRadius="4">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Width="130" Text="Subtotal:" />
                                <TextBlock x:Name="BasketSubtotal" />
                            </StackPanel>
                            <StackPanel
                                x:Name="DiscountRow"
                                Orientation="Horizontal"
                                Visibility="Collapsed">
                                <TextBlock x:Name="DiscountLabel" Width="130" />
                                <TextBlock x:Name="DiscountAmount" Foreground="Green" />
                            </StackPanel>
                            <StackPanel
                                x:Name="FlexNoteRow"
                                Orientation="Horizontal"
                                Visibility="Collapsed">
                                <TextBlock Width="130" Text="Discount:" />
                                <TextBlock Foreground="#777" Text="Settled at end of month (flexible plan)" />
                            </StackPanel>
                            <Separator Margin="0,4" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    Width="130"
                                    FontWeight="Bold"
                                    Text="Total Due:" />
                                <TextBlock x:Name="BasketTotal" FontWeight="Bold" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <StackPanel
                        Grid.Row="3"
                        Margin="0,8,0,0"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                        <Button
                            Margin="0,0,8,0"
                            Click="Basket_Clear"
                            Content="Clear Basket" />
                        <Button
                            Click="Basket_Submit"
                            Content="Submit Order"
                            FontWeight="Bold" />
                    </StackPanel>
                </Grid>

                <!--  ══ MY ORDERS ══  -->
                <Grid
                    x:Name="PanelMyOrders"
                    Margin="20"
                    Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="300" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel
                        Grid.ColumnSpan="2"
                        Margin="0,0,0,12"
                        Orientation="Horizontal">
                        <TextBlock
                            FontSize="20"
                            FontWeight="Bold"
                            Text="My Orders" />
                        <Button
                            Margin="16,0,0,0"
                            Click="MyOrders_Refresh"
                            Content="Refresh" />
                    </StackPanel>
                    <DataGrid
                        x:Name="MyOrdersGrid"
                        Grid.Row="1"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        IsReadOnly="True"
                        SelectionChanged="MyOrders_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding OrderId}"
                                Header="Order ID" />
                            <DataGridTextColumn
                                Width="100"
                                Binding="{Binding OrderDate, StringFormat=\{0:dd/MM/yyyy\}}"
                                Header="Date" />
                            <DataGridTextColumn
                                Width="100"
                                Binding="{Binding Status}"
                                Header="Status" />
                            <DataGridTextColumn
                                Width="90"
                                Binding="{Binding TotalAmount, StringFormat=£\{0:N2\}}"
                                Header="Total" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <Border
                        Grid.Row="1"
                        Grid.Column="1"
                        Margin="10,0,0,0"
                        Padding="10"
                        Background="White"
                        BorderBrush="#CCC"
                        BorderThickness="1">
                        <ScrollViewer>
                            <StackPanel>
                                <TextBlock
                                    Margin="0,0,0,8"
                                    FontWeight="Bold"
                                    Text="Order Detail" />
                                <TextBox
                                    x:Name="OrderDetailBox"
                                    Height="500"
                                    AcceptsReturn="True"
                                    BorderThickness="0"
                                    FontFamily="Consolas"
                                    FontSize="11"
                                    IsReadOnly="True"
                                    TextWrapping="Wrap"
                                    VerticalScrollBarVisibility="Auto" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!--  ══ MY BALANCE ══  -->
                <Grid
                    x:Name="PanelMyBalance"
                    Margin="20"
                    Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="300" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel
                        Grid.ColumnSpan="2"
                        Margin="0,0,0,12"
                        Orientation="Horizontal">
                        <TextBlock
                            FontSize="20"
                            FontWeight="Bold"
                            Text="My Balance" />
                        <Button
                            Margin="16,0,0,0"
                            Click="MyBalance_Refresh"
                            Content="Refresh" />
                    </StackPanel>
                    <DataGrid
                        x:Name="MyInvoicesGrid"
                        Grid.Row="1"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        IsReadOnly="True"
                        SelectionChanged="MyBalance_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding InvoiceId}"
                                Header="Invoice ID" />
                            <DataGridTextColumn
                                Width="100"
                                Binding="{Binding InvoiceDate, StringFormat=\{0:dd/MM/yyyy\}}"
                                Header="Date" />
                            <DataGridTextColumn
                                Width="90"
                                Binding="{Binding DueDate}"
                                Header="Due" />
                            <DataGridTextColumn
                                Width="90"
                                Binding="{Binding AmountDue, StringFormat=£\{0:N2\}}"
                                Header="Amount Due" />
                            <DataGridTextColumn
                                Width="80"
                                Binding="{Binding TotalPaid, StringFormat=£\{0:N2\}}"
                                Header="Paid" />
                            <DataGridTextColumn
                                Width="90"
                                Binding="{Binding PaymentStatus}"
                                Header="Status" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <Border
                        Grid.Row="1"
                        Grid.Column="1"
                        Margin="10,0,0,0"
                        Padding="10"
                        Background="White"
                        BorderBrush="#CCC"
                        BorderThickness="1">
                        <ScrollViewer>
                            <StackPanel>
                                <TextBlock
                                    Margin="0,0,0,8"
                                    FontWeight="Bold"
                                    Text="Invoice Detail" />
                                <TextBox
                                    x:Name="InvoiceDetailBox"
                                    Height="500"
                                    AcceptsReturn="True"
                                    BorderThickness="0"
                                    FontFamily="Consolas"
                                    FontSize="11"
                                    IsReadOnly="True"
                                    TextWrapping="Wrap"
                                    VerticalScrollBarVisibility="Auto" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!--  ══ MANAGE ACCOUNTS ══  -->
                <Grid
                    x:Name="PanelManageAccounts"
                    Margin="20"
                    Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        Margin="0,0,0,12"
                        FontSize="20"
                        FontWeight="Bold"
                        Text="Manage Accounts" />
                    <TabControl Grid.Row="1">

                        <!--  MERCHANT TAB  -->
                        <TabItem Header="Merchant Accounts">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <StackPanel Margin="0,8,0,8" Orientation="Horizontal">
                                    <TextBox
                                        x:Name="MerchantSearch"
                                        Width="220"
                                        Margin="0,0,6,0"
                                        VerticalContentAlignment="Center" />
                                    <Button
                                        Margin="0,0,4,0"
                                        Click="Merchants_Search"
                                        Content="Search" />
                                    <Button Click="Merchants_ClearSearch" Content="Clear" />
                                </StackPanel>
                                <DataGrid
                                    x:Name="MerchantsGrid"
                                    Grid.Row="1"
                                    AutoGenerateColumns="False"
                                    CanUserAddRows="False"
                                    IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn
                                            Width="50"
                                            Binding="{Binding MerchantId}"
                                            Header="ID" />
                                        <DataGridTextColumn
                                            Width="*"
                                            Binding="{Binding CompanyName}"
                                            Header="Company" />
                                        <DataGridTextColumn
                                            Width="180"
                                            Binding="{Binding Email}"
                                            Header="Email" />
                                        <DataGridTextColumn
                                            Width="90"
                                            Binding="{Binding CurrentBalance, StringFormat=£\{0:N2\}}"
                                            Header="Balance" />
                                        <DataGridTextColumn
                                            Width="100"
                                            Binding="{Binding AccountStatus}"
                                            Header="Status" />
                                        <DataGridTextColumn
                                            Width="50"
                                            Binding="{Binding IsActive}"
                                            Header="Is Active" />

                                        <DataGridTemplateColumn Width="280" Header="Actions">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button
                                                            Margin="2"
                                                            Click="Merchant_Edit"
                                                            Content="Edit"
                                                            FontSize="10"
                                                            Tag="{Binding}" />
                                                        <Button
                                                            Margin="2"
                                                            Click="Merchant_Restore"
                                                            Content="Restore"
                                                            FontSize="10"
                                                            Tag="{Binding}" />
                                                        <Button
                                                            Margin="2"
                                                            Click="Merchant_Deactivate"
                                                            Content="Deactivate"
                                                            FontSize="10"
                                                            Tag="{Binding}" />
                                                        <Button
                                                            Margin="2"
                                                            Click="Merchant_Reactivate"
                                                            Content="Reactivate"
                                                            FontSize="10"
                                                            Tag="{Binding}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>

                        <!--  STAFF TAB (admin only)  -->
                        <TabItem x:Name="StaffTab" Header="Staff Accounts">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Button
                                    Margin="0,8,0,8"
                                    HorizontalAlignment="Left"
                                    Click="Staff_Refresh"
                                    Content="Refresh" />
                                <DataGrid
                                    x:Name="StaffGrid"
                                    Grid.Row="1"
                                    AutoGenerateColumns="False"
                                    CanUserAddRows="False"
                                    IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn
                                            Width="50"
                                            Binding="{Binding UserId}"
                                            Header="ID" />
                                        <DataGridTextColumn
                                            Width="*"
                                            Binding="{Binding Username}"
                                            Header="Username" />
                                        <DataGridTextColumn
                                            Width="100"
                                            Binding="{Binding Role}"
                                            Header="Role" />
                                        <DataGridTextColumn
                                            Width="60"
                                            Binding="{Binding IsActive}"
                                            Header="Active" />
                                        <DataGridTemplateColumn Width="290" Header="Actions">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button
                                                            Margin="2"
                                                            Click="Staff_ChangeRole"
                                                            Content="Change Role"
                                                            FontSize="10"
                                                            Tag="{Binding}" />
                                                        <Button
                                                            Margin="2"
                                                            Click="Staff_ResetPassword"
                                                            Content="Reset Pwd"
                                                            FontSize="10"
                                                            Tag="{Binding}" />
                                                        <Button
                                                            Margin="2"
                                                            Click="Staff_Deactivate"
                                                            Content="Deactivate"
                                                            FontSize="10"
                                                            Tag="{Binding}" />
                                                        <Button
                                                            Margin="2"
                                                            Click="Staff_Reactivate"
                                                            Content="Reactivate"
                                                            FontSize="10"
                                                            Tag="{Binding}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>

                        <!--  CREATE ACCOUNT TAB (admin only)  -->
                        <TabItem x:Name="CreateAccountTab" Header="Create Account">
                            <ScrollViewer>
                                <StackPanel Margin="12">
                                    <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                                        <RadioButton
                                            x:Name="RadioMerchantForm"
                                            Margin="0,0,16,0"
                                            Content="Merchant"
                                            IsChecked="True" />
                                        <RadioButton x:Name="RadioStaffForm" Content="Staff" />
                                    </StackPanel>

                                    <StackPanel x:Name="MerchantCreateForm">
                                        <TextBlock
                                            Margin="0,0,0,8"
                                            FontWeight="Bold"
                                            Text="Create Merchant Account" />
                                        <Label Content="Username *" />
                                        <TextBox x:Name="NewMerchantUsername" Margin="0,0,0,4" />
                                        <Label Content="Password *" />
                                        <PasswordBox x:Name="NewMerchantPassword" Margin="0,0,0,4" />
                                        <Label Content="Company Name *" />
                                        <TextBox x:Name="NewMerchantCompany" Margin="0,0,0,4" />
                                        <Label Content="Address *" />
                                        <TextBox x:Name="NewMerchantAddress" Margin="0,0,0,4" />
                                        <Label Content="Email *" />
                                        <TextBox x:Name="NewMerchantEmail" Margin="0,0,0,4" />
                                        <Label Content="Phone *" />
                                        <TextBox x:Name="NewMerchantPhone" Margin="0,0,0,4" />
                                        <Label Content="Credit Limit (£) *" />
                                        <TextBox x:Name="NewMerchantCreditLimit" Margin="0,0,0,4" />
                                        <Label Content="Discount Plan ID * (required by server)" />
                                        <TextBox x:Name="NewMerchantDiscountPlan" Margin="0,0,0,12" />
                                        <Button
                                            HorizontalAlignment="Left"
                                            Click="CreateMerchant_Submit"
                                            Content="Create Merchant Account" />
                                    </StackPanel>

                                    <StackPanel x:Name="StaffCreateForm" Visibility="Collapsed">
                                        <TextBlock
                                            Margin="0,0,0,8"
                                            FontWeight="Bold"
                                            Text="Create Staff Account" />
                                        <Label Content="Username *" />
                                        <TextBox x:Name="NewStaffUsername" Margin="0,0,0,4" />
                                        <Label Content="Password *" />
                                        <PasswordBox x:Name="NewStaffPassword" Margin="0,0,0,4" />
                                        <Label Content="Role *" />
                                        <ComboBox x:Name="NewStaffRole" Margin="0,0,0,12">
                                            <ComboBoxItem Content="ADMIN" />
                                            <ComboBoxItem Content="MANAGER" />
                                            <ComboBoxItem Content="ACCOUNTANT" />
                                            <ComboBoxItem Content="DIRECTOR" />
                                        </ComboBox>
                                        <Button
                                            HorizontalAlignment="Left"
                                            Click="CreateStaff_Submit"
                                            Content="Create Staff Account" />
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Grid>

                <!--  ══ CATALOGUE MANAGEMENT ══  -->
                <Grid
                    x:Name="PanelCatalogueMgmt"
                    Margin="20"
                    Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        Margin="0,0,0,12"
                        FontSize="20"
                        FontWeight="Bold"
                        Text="Catalogue / Stock Management" />
                    <StackPanel
                        Grid.Row="1"
                        Margin="0,0,0,8"
                        Orientation="Horizontal">
                        <Button
                            Margin="0,0,6,0"
                            Click="CatMgmt_Refresh"
                            Content="Refresh" />
                        <Button Click="CatMgmt_AddProduct" Content="Add Product" />
                    </StackPanel>
                    <DataGrid
                        x:Name="CatMgmtGrid"
                        Grid.Row="2"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Width="110"
                                Binding="{Binding ProductId}"
                                Header="Code" />
                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding Description}"
                                Header="Description" />
                            <DataGridTextColumn
                                Width="85"
                                Binding="{Binding UnitPrice, StringFormat=£\{0:N2\}}"
                                Header="Unit Price" />
                            <DataGridTextColumn
                                Width="70"
                                Binding="{Binding Availability}"
                                Header="In Stock" />
                            <DataGridTextColumn
                                Width="75"
                                Binding="{Binding MinStockLevel}"
                                Header="Min Stock" />
                            <DataGridTextColumn
                                Width="55"
                                Binding="{Binding IsActive}"
                                Header="Active" />
                            <DataGridTemplateColumn Width="280" Header="Actions">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button
                                                Margin="2"
                                                Click="CatMgmt_Edit"
                                                Content="Edit"
                                                FontSize="10"
                                                Tag="{Binding}" />
                                            <Button
                                                Margin="2"
                                                Click="CatMgmt_StockIn"
                                                Content="Stock In"
                                                FontSize="10"
                                                Tag="{Binding}" />
                                            <Button
                                                Margin="2"
                                                Click="CatMgmt_Deactivate"
                                                Content="Deactivate"
                                                FontSize="10"
                                                Tag="{Binding}" />
                                            <Button
                                                Margin="2"
                                                Click="CatMgmt_Reactivate"
                                                Content="Reactivate"
                                                FontSize="10"
                                                Tag="{Binding}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <!--  ══ ORDERS MANAGEMENT ══  -->
                <Grid
                    x:Name="PanelOrders"
                    Margin="20"
                    Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        Margin="0,0,0,12"
                        FontSize="20"
                        FontWeight="Bold"
                        Text="Orders Management" />
                    <StackPanel
                        Grid.Row="1"
                        Margin="0,0,0,8"
                        Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            Text="Filter:" />
                        <ComboBox
                            x:Name="OrderStatusFilter"
                            Width="140"
                            Margin="0,0,8,0">
                            <ComboBoxItem Content="(all)" IsSelected="True" />
                            <ComboBoxItem Content="ACCEPTED" />
                            <ComboBoxItem Content="PROCESSING" />
                            <ComboBoxItem Content="DISPATCHED" />
                            <ComboBoxItem Content="DELIVERED" />
                            <ComboBoxItem Content="CANCELLED" />
                        </ComboBox>
                        <Button Click="Orders_Load" Content="Load" />
                    </StackPanel>
                    <DataGrid
                        x:Name="AllOrdersGrid"
                        Grid.Row="2"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding OrderId}"
                                Header="Order ID" />
                            <DataGridTextColumn
                                Width="160"
                                Binding="{Binding MerchantName}"
                                Header="Merchant" />
                            <DataGridTextColumn
                                Width="90"
                                Binding="{Binding OrderDate, StringFormat=\{0:dd/MM/yyyy\}}"
                                Header="Date" />
                            <DataGridTextColumn
                                Width="90"
                                Binding="{Binding TotalAmount, StringFormat=£\{0:N2\}}"
                                Header="Total" />
                            <DataGridTextColumn
                                Width="100"
                                Binding="{Binding Status}"
                                Header="Status" />
                            <DataGridTemplateColumn Width="190" Header="Actions">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button
                                                Margin="2"
                                                Click="Order_UpdateStatus"
                                                Content="Update Status"
                                                FontSize="10"
                                                Tag="{Binding}" />
                                            <Button
                                                Margin="2"
                                                Click="Order_Dispatch"
                                                Content="Dispatch"
                                                FontSize="10"
                                                Tag="{Binding}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <!--  ══ DISCOUNT PLANS ══  -->
                <Grid
                    x:Name="PanelDiscountPlans"
                    Margin="20"
                    Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        Margin="0,0,0,12"
                        FontSize="20"
                        FontWeight="Bold"
                        Text="Discount Plans" />
                    <Button
                        Grid.Row="1"
                        Margin="0,0,0,8"
                        HorizontalAlignment="Left"
                        Click="DiscountPlans_Refresh"
                        Content="Refresh" />
                    <DataGrid
                        x:Name="DiscountPlansGrid"
                        Grid.Row="2"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Width="50"
                                Binding="{Binding PlanId}"
                                Header="ID" />
                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding PlanName}"
                                Header="Name" />
                            <DataGridTextColumn
                                Width="90"
                                Binding="{Binding PlanType}"
                                Header="Type" />
                            <DataGridTextColumn
                                Width="160"
                                Binding="{Binding Summary}"
                                Header="Detail" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <!--  Create plan  -->
                    <Border
                        Grid.Row="3"
                        Margin="0,8,0,0"
                        Padding="12"
                        Background="White"
                        BorderBrush="#CCC"
                        BorderThickness="1"
                        CornerRadius="4">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,8"
                                FontWeight="Bold"
                                Text="Create New Plan" />
                            <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                                <RadioButton
                                    x:Name="RadioFixed"
                                    Margin="0,0,16,0"
                                    Content="Fixed"
                                    IsChecked="True" />
                                <RadioButton x:Name="RadioFlexible" Content="Flexible" />
                            </StackPanel>
                            <StackPanel x:Name="FixedPlanForm">
                                <StackPanel Orientation="Horizontal">
                                    <Label Width="85" Content="Plan Name:" />
                                    <TextBox
                                        x:Name="FixedPlanName"
                                        Width="160"
                                        Margin="0,0,8,0" />
                                    <Label Width="70" Content="Rate (%):" />
                                    <TextBox
                                        x:Name="FixedPlanRate"
                                        Width="60"
                                        Margin="0,0,8,0" />
                                    <Button Click="CreateFixedPlan" Content="Create" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel x:Name="FlexiblePlanForm" Visibility="Collapsed">
                                <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                                    <Label Width="85" Content="Plan Name:" />
                                    <TextBox x:Name="FlexPlanName" Width="200" />
                                </StackPanel>
                                <TextBlock
                                    Margin="0,4,0,2"
                                    FontSize="11"
                                    Foreground="#555"
                                    Text="Tiers — one per line: minOrderVal , maxOrderVal , discountRate" />
                                <TextBlock
                                    Margin="0,0,0,4"
                                    FontSize="10"
                                    Foreground="#888"
                                    Text="(leave maxOrderVal blank on final tier for open-ended)" />
                                <TextBox
                                    x:Name="FlexPlanTiers"
                                    Height="64"
                                    Margin="0,0,0,8"
                                    AcceptsReturn="True"
                                    FontFamily="Consolas"
                                    FontSize="11" />
                                <Button
                                    HorizontalAlignment="Left"
                                    Click="CreateFlexPlan"
                                    Content="Create Flexible Plan" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!--  ══ RECORD PAYMENT ══  -->
                <ScrollViewer
                    x:Name="PanelRecordPayment"
                    Margin="20"
                    Visibility="Collapsed">
                    <StackPanel MaxWidth="480">
                        <TextBlock
                            Margin="0,0,0,16"
                            FontSize="20"
                            FontWeight="Bold"
                            Text="Record Payment" />
                        <Label Content="Merchant ID" />
                        <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                            <TextBox
                                x:Name="PaymentMerchantId"
                                Width="100"
                                Margin="0,0,8,0"
                                VerticalContentAlignment="Center" />
                            <Button Click="Payment_LoadInvoices" Content="Load Invoices" />
                        </StackPanel>
                        <Label Content="Invoice" />
                        <ComboBox x:Name="PaymentInvoiceCombo" Margin="0,0,0,8" />
                        <Label Content="Amount Paid (£)" />
                        <TextBox x:Name="PaymentAmount" Margin="0,0,0,8" />
                        <Label Content="Payment Method" />
                        <ComboBox x:Name="PaymentMethod" Margin="0,0,0,8">
                            <ComboBoxItem Content="BANK_TRANSFER" IsSelected="True" />
                            <ComboBoxItem Content="CARD" />
                            <ComboBoxItem Content="CHEQUE" />
                        </ComboBox>
                        <Label Content="Payment Date" />
                        <DatePicker x:Name="PaymentDate" Margin="0,0,0,8" />
                        <Label Content="Notes (optional)" />
                        <TextBox x:Name="PaymentNotes" Margin="0,0,0,16" />
                        <Button
                            HorizontalAlignment="Left"
                            Click="Payment_Save"
                            Content="Save Payment"
                            FontWeight="Bold" />
                    </StackPanel>
                </ScrollViewer>

                <!--  ══ REPORTS ══  -->
                <Grid
                    x:Name="PanelReports"
                    Margin="20"
                    Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        Margin="0,0,0,12"
                        FontSize="20"
                        FontWeight="Bold"
                        Text="Reports" />
                    <Border
                        Grid.Row="1"
                        Margin="0,0,0,8"
                        Padding="12"
                        Background="White"
                        BorderBrush="#CCC"
                        BorderThickness="1"
                        CornerRadius="4">
                        <WrapPanel>
                            <StackPanel Margin="0,0,12,0">
                                <Label Content="Report Type" />
                                <ComboBox x:Name="ReportType" Width="220">
                                    <ComboBoxItem Content="RPT-01: Turnover" IsSelected="True" />
                                    <ComboBoxItem Content="RPT-02: Merchant Orders Summary" />
                                    <ComboBoxItem Content="RPT-03: Merchant Detailed" />
                                    <ComboBoxItem Content="RPT-04: Invoice List (Merchant)" />
                                    <ComboBoxItem Content="RPT-05: All Invoices" />
                                    <ComboBoxItem Content="RPT-07: Low Stock" />
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Margin="0,0,12,0">
                                <Label Content="Merchant ID (RPT-02/03/04)" />
                                <TextBox x:Name="ReportMerchantId" Width="100" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,0">
                                <Label Content="From" />
                                <DatePicker x:Name="ReportFrom" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,0">
                                <Label Content="To" />
                                <DatePicker x:Name="ReportTo" />
                            </StackPanel>
                            <StackPanel VerticalAlignment="Bottom">
                                <Button
                                    Click="Report_Generate"
                                    Content="Generate"
                                    FontWeight="Bold" />
                                <Button
                                    Margin="0,4,0,0"
                                    Click="Report_Print"
                                    Content="Print" />
                            </StackPanel>
                        </WrapPanel>
                    </Border>
                    <ScrollViewer
                        Grid.Row="2"
                        Background="White"
                        BorderBrush="#CCC"
                        BorderThickness="1">
                        <TextBox
                            x:Name="ReportOutput"
                            Padding="12"
                            AcceptsReturn="True"
                            BorderThickness="0"
                            FontFamily="Consolas"
                            FontSize="11"
                            IsReadOnly="True"
                            TextWrapping="Wrap" />
                    </ScrollViewer>
                </Grid>

                <!--  ══ AUDIT LOG ══  -->
                <Grid
                    x:Name="PanelAuditLog"
                    Margin="20"
                    Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        Margin="0,0,0,12"
                        FontSize="20"
                        FontWeight="Bold"
                        Text="Audit Log" />
                    <WrapPanel Grid.Row="1" Margin="0,0,0,8">
                        <StackPanel Margin="0,0,8,0">
                            <Label Content="User ID" />
                            <TextBox x:Name="AuditUserId" Width="80" />
                        </StackPanel>
                        <StackPanel Margin="0,0,8,0">
                            <Label Content="Target Type" />
                            <TextBox x:Name="AuditTargetType" Width="110" />
                        </StackPanel>
                        <StackPanel Margin="0,0,8,0">
                            <Label Content="Target ID" />
                            <TextBox x:Name="AuditTargetId" Width="90" />
                        </StackPanel>
                        <StackPanel Margin="0,0,8,0">
                            <Label Content="From" />
                            <DatePicker x:Name="AuditFrom" />
                        </StackPanel>
                        <StackPanel Margin="0,0,8,0">
                            <Label Content="To" />
                            <DatePicker x:Name="AuditTo" />
                        </StackPanel>
                        <StackPanel VerticalAlignment="Bottom">
                            <Button Click="AuditLog_Load" Content="Load" />
                        </StackPanel>
                    </WrapPanel>
                    <DataGrid
                        x:Name="AuditGrid"
                        Grid.Row="2"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Width="130"
                                Binding="{Binding LoggedAt, StringFormat=\{0:dd/MM/yyyy HH:mm\}}"
                                Header="Time" />
                            <DataGridTextColumn
                                Width="110"
                                Binding="{Binding Username}"
                                Header="User" />
                            <DataGridTextColumn
                                Width="160"
                                Binding="{Binding Action}"
                                Header="Action" />
                            <DataGridTextColumn
                                Width="110"
                                Binding="{Binding TargetType}"
                                Header="Target Type" />
                            <DataGridTextColumn
                                Width="110"
                                Binding="{Binding TargetId}"
                                Header="Target ID" />
                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding Details}"
                                Header="Details" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

            </Grid>
        </Border>
    </Grid>
</Window>

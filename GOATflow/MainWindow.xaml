<Window x:Class="GOATflow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GOATflow" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="185"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ SIDEBAR ═══ -->
        <StackPanel Grid.Column="0" Background="#2D2D2D">
            <TextBlock Text="GOATflow" Foreground="White" FontSize="18" FontWeight="Bold"
                       Margin="12,16,12,8"/>
            <TextBlock x:Name="UserLabel" Foreground="#AAAAAA" FontSize="12"
                       Margin="12,0,12,12" TextWrapping="Wrap"/>

            <!-- Payment reminder (merchant only) -->
            <Border x:Name="PaymentReminderBanner" Background="#8B6914" Visibility="Collapsed"
                    Margin="8,0,8,8" CornerRadius="3" Padding="8,6">
                <TextBlock Text="⚠ Payment overdue. Please settle your balance."
                           Foreground="White" FontSize="11" TextWrapping="Wrap"/>
            </Border>

            <!-- Nav buttons — all Collapsed by default, shown per role -->
            <Button x:Name="NavAccountInfo"    Content="Account Info"       Style="{StaticResource NavBtn}" Visibility="Collapsed" Click="NavClick"/>
            <Button x:Name="NavCatalogue"      Content="Browse Catalogue"   Style="{StaticResource NavBtn}" Visibility="Collapsed" Click="NavClick"/>
            <Button x:Name="NavMyOrders"       Content="My Orders"          Style="{StaticResource NavBtn}" Visibility="Collapsed" Click="NavClick"/>
            <Button x:Name="NavMyBalance"      Content="My Balance"         Style="{StaticResource NavBtn}" Visibility="Collapsed" Click="NavClick"/>
            <Button x:Name="NavManageAccounts" Content="Manage Accounts"    Style="{StaticResource NavBtn}" Visibility="Collapsed" Click="NavClick"/>
            <Button x:Name="NavCatalogueMgmt"  Content="Catalogue / Stock"  Style="{StaticResource NavBtn}" Visibility="Collapsed" Click="NavClick"/>
            <Button x:Name="NavOrders"         Content="Orders Management"  Style="{StaticResource NavBtn}" Visibility="Collapsed" Click="NavClick"/>
            <Button x:Name="NavDiscountPlans"  Content="Discount Plans"     Style="{StaticResource NavBtn}" Visibility="Collapsed" Click="NavClick"/>
            <Button x:Name="NavRecordPayment"  Content="Record Payment"     Style="{StaticResource NavBtn}" Visibility="Collapsed" Click="NavClick"/>
            <Button x:Name="NavReports"        Content="Reports"            Style="{StaticResource NavBtn}" Visibility="Collapsed" Click="NavClick"/>
            <Button x:Name="NavAuditLog"       Content="Audit Log"          Style="{StaticResource NavBtn}" Visibility="Collapsed" Click="NavClick"/>

            <!-- Notifications (admin/manager) -->
            <Border x:Name="NotifPanel" Visibility="Collapsed" Margin="8,12,8,0"
                    Background="#3A3A3A" CornerRadius="3" Padding="8">
                <StackPanel>
                    <TextBlock Text="Notifications" Foreground="#CCCCCC" FontWeight="Bold" FontSize="12"/>
                    <TextBlock x:Name="NotifText" Foreground="#FF7070" FontSize="11"
                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Button x:Name="NavLogout" Content="Logout" Style="{StaticResource NavBtn}"
                    Click="NavClick" Margin="0,20,0,0" Foreground="#FF7070"/>
        </StackPanel>

        <!-- ═══ CONTENT AREA ═══ -->
        <Border Grid.Column="1" Background="#F5F5F5">
            <Grid>

                <!-- ══ ACCOUNT INFO ══ -->
                <ScrollViewer x:Name="PanelAccountInfo" Visibility="Collapsed" Margin="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="Account Info" FontSize="20" FontWeight="Bold"/>
                            <Button Content="Refresh" Margin="16,0,0,0" Click="AccountInfo_Refresh"/>
                        </StackPanel>
                        <TextBox x:Name="AccountInfoBox" IsReadOnly="True" TextWrapping="Wrap"
                                 AcceptsReturn="True" Height="300" VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" FontSize="13" Padding="8"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- ══ BROWSE CATALOGUE ══ -->
                <Grid x:Name="PanelCatalogue" Visibility="Collapsed" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Browse Catalogue" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBox x:Name="CatalogueSearch" Width="240" Margin="0,0,6,0" VerticalContentAlignment="Center"/>
                        <Button Content="Search" Click="Catalogue_Search" Margin="0,0,4,0"/>
                        <Button Content="Clear"  Click="Catalogue_Clear"/>
                    </StackPanel>
                    <!-- Binds to List<CatalogueItemDTO> — field is "description" not "name" -->
                    <DataGrid x:Name="CatalogueGrid" Grid.Row="2" AutoGenerateColumns="False"
                              IsReadOnly="True" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Code"         Binding="{Binding ProductId}"    Width="110"/>
                            <DataGridTextColumn Header="Description"  Binding="{Binding Description}"  Width="*"/>
                            <DataGridTextColumn Header="Pack Type"    Binding="{Binding PackageType}"  Width="90"/>
                            <DataGridTextColumn Header="Unit"         Binding="{Binding Unit}"         Width="60"/>
                            <DataGridTextColumn Header="Unit Price"   Binding="{Binding UnitPrice, StringFormat=£\{0:N2\}}" Width="85"/>
                            <DataGridTextColumn Header="In Stock"     Binding="{Binding Availability}" Width="70"/>
                            <DataGridTemplateColumn Header="Action"   Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Add to Basket" Tag="{Binding}"
                                                Click="Catalogue_AddToBasket" FontSize="10" Padding="4,2"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Button Grid.Row="3" Content="View Basket / Place Order" Margin="0,8,0,0"
                            HorizontalAlignment="Right" Click="NavToBasket" FontWeight="Bold"/>
                </Grid>

                <!-- ══ BASKET / PLACE ORDER ══ -->
                <Grid x:Name="PanelBasket" Visibility="Collapsed" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Place Order" FontSize="20" FontWeight="Bold"/>
                        <Button x:Name="BackToCatalogue" Content="← Back to Catalogue"
                                Margin="16,0,0,0" Click="NavClick"/>
                    </StackPanel>
                    <!-- Binds to List<BasketItem> — LineTotal is computed property -->
                    <DataGrid x:Name="BasketGrid" Grid.Row="1" AutoGenerateColumns="False"
                              CanUserAddRows="False" IsReadOnly="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Code"        Binding="{Binding ProductId}"   Width="110" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"   IsReadOnly="True"/>
                            <DataGridTextColumn Header="Unit Price"  Binding="{Binding UnitPrice, StringFormat=£\{0:N2\}}" Width="85" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Qty"         Binding="{Binding Quantity}"    Width="55"/>
                            <DataGridTextColumn Header="Line Total"  Binding="{Binding LineTotal, StringFormat=£\{0:N2\}}" Width="90" IsReadOnly="True"/>
                            <DataGridTemplateColumn Header="" Width="55">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="✕" Tag="{Binding}" Click="Basket_Remove" FontSize="11"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <!-- Order summary -->
                    <Border Grid.Row="2" Background="White" Margin="0,8,0,0" Padding="12"
                            CornerRadius="4" BorderBrush="#CCCCCC" BorderThickness="1">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Subtotal:" Width="130"/>
                                <TextBlock x:Name="BasketSubtotal"/>
                            </StackPanel>
                            <StackPanel x:Name="DiscountRow" Orientation="Horizontal" Visibility="Collapsed">
                                <TextBlock x:Name="DiscountLabel" Width="130"/>
                                <TextBlock x:Name="DiscountAmount" Foreground="Green"/>
                            </StackPanel>
                            <StackPanel x:Name="FlexNoteRow" Orientation="Horizontal" Visibility="Collapsed">
                                <TextBlock Text="Discount:" Width="130"/>
                                <TextBlock Text="Settled at end of month (flexible plan)" Foreground="#777"/>
                            </StackPanel>
                            <Separator Margin="0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Total Due:" Width="130" FontWeight="Bold"/>
                                <TextBlock x:Name="BasketTotal" FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Content="Clear Basket" Click="Basket_Clear" Margin="0,0,8,0"/>
                        <Button Content="Submit Order" Click="Basket_Submit" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>

                <!-- ══ MY ORDERS ══ -->
                <Grid x:Name="PanelMyOrders" Visibility="Collapsed" Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="My Orders" FontSize="20" FontWeight="Bold"/>
                        <Button Content="Refresh" Margin="16,0,0,0" Click="MyOrders_Refresh"/>
                    </StackPanel>
                    <!-- Binds to List<OrderDTO> -->
                    <DataGrid x:Name="MyOrdersGrid" Grid.Row="1" AutoGenerateColumns="False"
                              IsReadOnly="True" CanUserAddRows="False"
                              SelectionChanged="MyOrders_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Order ID"  Binding="{Binding OrderId}"    Width="*"/>
                            <DataGridTextColumn Header="Date"      Binding="{Binding OrderDate, StringFormat=\{0:dd/MM/yyyy\}}" Width="100"/>
                            <DataGridTextColumn Header="Status"    Binding="{Binding Status}"     Width="100"/>
                            <DataGridTextColumn Header="Total"     Binding="{Binding TotalAmount, StringFormat=£\{0:N2\}}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Border Grid.Column="1" Grid.Row="1" Background="White" Margin="10,0,0,0"
                            BorderBrush="#CCC" BorderThickness="1" Padding="10">
                        <ScrollViewer>
                            <StackPanel>
                                <TextBlock Text="Order Detail" FontWeight="Bold" Margin="0,0,0,8"/>
                                <TextBox x:Name="OrderDetailBox" IsReadOnly="True" TextWrapping="Wrap"
                                         AcceptsReturn="True" BorderThickness="0"
                                         FontFamily="Consolas" FontSize="11"
                                         Height="500" VerticalScrollBarVisibility="Auto"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- ══ MY BALANCE ══ -->
                <Grid x:Name="PanelMyBalance" Visibility="Collapsed" Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="My Balance" FontSize="20" FontWeight="Bold"/>
                        <Button Content="Refresh" Margin="16,0,0,0" Click="MyBalance_Refresh"/>
                    </StackPanel>
                    <!-- Binds to List<InvoiceDTO> — fields: invoiceId, invoiceDate, amountDue, totalPaid, paymentStatus -->
                    <DataGrid x:Name="MyInvoicesGrid" Grid.Row="1" AutoGenerateColumns="False"
                              IsReadOnly="True" CanUserAddRows="False"
                              SelectionChanged="MyBalance_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Invoice ID"   Binding="{Binding InvoiceId}"   Width="*"/>
                            <DataGridTextColumn Header="Date"         Binding="{Binding InvoiceDate, StringFormat=\{0:dd/MM/yyyy\}}" Width="100"/>
                            <DataGridTextColumn Header="Due"          Binding="{Binding DueDate}"     Width="90"/>
                            <DataGridTextColumn Header="Amount Due"   Binding="{Binding AmountDue, StringFormat=£\{0:N2\}}"  Width="90"/>
                            <DataGridTextColumn Header="Paid"         Binding="{Binding TotalPaid, StringFormat=£\{0:N2\}}"  Width="80"/>
                            <DataGridTextColumn Header="Status"       Binding="{Binding PaymentStatus}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Border Grid.Column="1" Grid.Row="1" Background="White" Margin="10,0,0,0"
                            BorderBrush="#CCC" BorderThickness="1" Padding="10">
                        <ScrollViewer>
                            <StackPanel>
                                <TextBlock Text="Invoice Detail" FontWeight="Bold" Margin="0,0,0,8"/>
                                <TextBox x:Name="InvoiceDetailBox" IsReadOnly="True" TextWrapping="Wrap"
                                         AcceptsReturn="True" BorderThickness="0"
                                         FontFamily="Consolas" FontSize="11"
                                         Height="500" VerticalScrollBarVisibility="Auto"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- ══ MANAGE ACCOUNTS ══ -->
                <Grid x:Name="PanelManageAccounts" Visibility="Collapsed" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Manage Accounts" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>
                    <TabControl Grid.Row="1">

                        <!-- MERCHANT TAB -->
                        <TabItem Header="Merchant Accounts">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,8">
                                    <TextBox x:Name="MerchantSearch" Width="220" Margin="0,0,6,0"
                                             VerticalContentAlignment="Center"/>
                                    <Button Content="Search" Click="Merchants_Search" Margin="0,0,4,0"/>
                                    <Button Content="Clear"  Click="Merchants_ClearSearch"/>
                                </StackPanel>
                                <!-- Binds to List<MerchantDTO> -->
                                <DataGrid x:Name="MerchantsGrid" Grid.Row="1" AutoGenerateColumns="False"
                                          IsReadOnly="True" CanUserAddRows="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID"      Binding="{Binding MerchantId}"   Width="50"/>
                                        <DataGridTextColumn Header="Company" Binding="{Binding CompanyName}"  Width="*"/>
                                        <DataGridTextColumn Header="Email"   Binding="{Binding Email}"        Width="180"/>
                                        <DataGridTextColumn Header="Balance" Binding="{Binding CurrentBalance, StringFormat=£\{0:N2\}}" Width="90"/>
                                        <DataGridTextColumn Header="Status"  Binding="{Binding AccountStatus}" Width="100"/>
                                        <DataGridTemplateColumn Header="Actions" Width="280">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Content="Edit"       Tag="{Binding}" Click="Merchant_Edit"       Margin="2" FontSize="10"/>
                                                        <Button Content="Restore"    Tag="{Binding}" Click="Merchant_Restore"    Margin="2" FontSize="10"/>
                                                        <Button Content="Deactivate" Tag="{Binding}" Click="Merchant_Deactivate" Margin="2" FontSize="10"/>
                                                        <Button Content="Reactivate" Tag="{Binding}" Click="Merchant_Reactivate" Margin="2" FontSize="10"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>

                        <!-- STAFF TAB (admin only) -->
                        <TabItem x:Name="StaffTab" Header="Staff Accounts">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Button Content="Refresh" HorizontalAlignment="Left"
                                        Margin="0,8,0,8" Click="Staff_Refresh"/>
                                <!-- Binds to List<StaffDTO> — field is userId not id -->
                                <DataGrid x:Name="StaffGrid" Grid.Row="1" AutoGenerateColumns="False"
                                          IsReadOnly="True" CanUserAddRows="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID"       Binding="{Binding UserId}"   Width="50"/>
                                        <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="*"/>
                                        <DataGridTextColumn Header="Role"     Binding="{Binding Role}"     Width="100"/>
                                        <DataGridTextColumn Header="Active"   Binding="{Binding IsActive}" Width="60"/>
                                        <DataGridTemplateColumn Header="Actions" Width="290">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Content="Change Role"  Tag="{Binding}" Click="Staff_ChangeRole"     Margin="2" FontSize="10"/>
                                                        <Button Content="Reset Pwd"    Tag="{Binding}" Click="Staff_ResetPassword"  Margin="2" FontSize="10"/>
                                                        <Button Content="Deactivate"   Tag="{Binding}" Click="Staff_Deactivate"     Margin="2" FontSize="10"/>
                                                        <Button Content="Reactivate"   Tag="{Binding}" Click="Staff_Reactivate"     Margin="2" FontSize="10"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>

                        <!-- CREATE ACCOUNT TAB (admin only) -->
                        <TabItem x:Name="CreateAccountTab" Header="Create Account">
                            <ScrollViewer>
                                <StackPanel Margin="12">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <RadioButton x:Name="RadioMerchantForm" Content="Merchant"
                                                     IsChecked="True" Margin="0,0,16,0"/>
                                        <RadioButton x:Name="RadioStaffForm"    Content="Staff"/>
                                    </StackPanel>

                                    <!-- Merchant creation form -->
                                    <StackPanel x:Name="MerchantCreateForm">
                                        <TextBlock Text="Create Merchant Account" FontWeight="Bold" Margin="0,0,0,8"/>
                                        <Label Content="Username *"/>
                                        <TextBox x:Name="NewMerchantUsername" Margin="0,0,0,4"/>
                                        <Label Content="Password *"/>
                                        <PasswordBox x:Name="NewMerchantPassword" Margin="0,0,0,4"/>
                                        <Label Content="Company Name *"/>
                                        <TextBox x:Name="NewMerchantCompany" Margin="0,0,0,4"/>
                                        <Label Content="Address *"/>
                                        <TextBox x:Name="NewMerchantAddress" Margin="0,0,0,4"/>
                                        <Label Content="Email *"/>
                                        <TextBox x:Name="NewMerchantEmail" Margin="0,0,0,4"/>
                                        <Label Content="Phone *"/>
                                        <TextBox x:Name="NewMerchantPhone" Margin="0,0,0,4"/>
                                        <Label Content="Credit Limit (£) *"/>
                                        <TextBox x:Name="NewMerchantCreditLimit" Margin="0,0,0,4"/>
                                        <Label Content="Discount Plan ID * (required by server)"/>
                                        <TextBox x:Name="NewMerchantDiscountPlan" Margin="0,0,0,12"/>
                                        <Button Content="Create Merchant Account" Click="CreateMerchant_Submit"
                                                HorizontalAlignment="Left"/>
                                    </StackPanel>

                                    <!-- Staff creation form -->
                                    <StackPanel x:Name="StaffCreateForm" Visibility="Collapsed">
                                        <TextBlock Text="Create Staff Account" FontWeight="Bold" Margin="0,0,0,8"/>
                                        <Label Content="Username *"/>
                                        <TextBox x:Name="NewStaffUsername" Margin="0,0,0,4"/>
                                        <Label Content="Password *"/>
                                        <PasswordBox x:Name="NewStaffPassword" Margin="0,0,0,4"/>
                                        <Label Content="Role *"/>
                                        <ComboBox x:Name="NewStaffRole" Margin="0,0,0,12">
                                            <ComboBoxItem Content="ADMIN"/>
                                            <ComboBoxItem Content="MANAGER"/>
                                            <ComboBoxItem Content="ACCOUNTANT"/>
                                            <ComboBoxItem Content="DIRECTOR"/>
                                        </ComboBox>
                                        <Button Content="Create Staff Account" Click="CreateStaff_Submit"
                                                HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Grid>

                <!-- ══ CATALOGUE MANAGEMENT ══ -->
                <Grid x:Name="PanelCatalogueMgmt" Visibility="Collapsed" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Catalogue / Stock Management" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Refresh"     Click="CatMgmt_Refresh"    Margin="0,0,6,0"/>
                        <Button Content="Add Product" Click="CatMgmt_AddProduct"/>
                    </StackPanel>
                    <!-- Binds to List<AdminCatalogueItemDTO> -->
                    <DataGrid x:Name="CatMgmtGrid" Grid.Row="2" AutoGenerateColumns="False"
                              IsReadOnly="True" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Code"        Binding="{Binding ProductId}"    Width="110"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}"  Width="*"/>
                            <DataGridTextColumn Header="Unit Price"  Binding="{Binding UnitPrice, StringFormat=£\{0:N2\}}" Width="85"/>
                            <DataGridTextColumn Header="In Stock"    Binding="{Binding Availability}" Width="70"/>
                            <DataGridTextColumn Header="Min Stock"   Binding="{Binding MinStockLevel}" Width="75"/>
                            <DataGridTextColumn Header="Active"      Binding="{Binding IsActive}"     Width="55"/>
                            <DataGridTemplateColumn Header="Actions" Width="280">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Edit"       Tag="{Binding}" Click="CatMgmt_Edit"        Margin="2" FontSize="10"/>
                                            <Button Content="Stock In"   Tag="{Binding}" Click="CatMgmt_StockIn"     Margin="2" FontSize="10"/>
                                            <Button Content="Deactivate" Tag="{Binding}" Click="CatMgmt_Deactivate"  Margin="2" FontSize="10"/>
                                            <Button Content="Reactivate" Tag="{Binding}" Click="CatMgmt_Reactivate"  Margin="2" FontSize="10"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <!-- ══ ORDERS MANAGEMENT ══ -->
                <Grid x:Name="PanelOrders" Visibility="Collapsed" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Orders Management" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <!-- Order.OrderStatus: ACCEPTED, PROCESSING, DISPATCHED, DELIVERED, CANCELLED -->
                        <ComboBox x:Name="OrderStatusFilter" Width="140" Margin="0,0,8,0">
                            <ComboBoxItem Content="(all)" IsSelected="True"/>
                            <ComboBoxItem Content="ACCEPTED"/>
                            <ComboBoxItem Content="PROCESSING"/>
                            <ComboBoxItem Content="DISPATCHED"/>
                            <ComboBoxItem Content="DELIVERED"/>
                            <ComboBoxItem Content="CANCELLED"/>
                        </ComboBox>
                        <Button Content="Load" Click="Orders_Load"/>
                    </StackPanel>
                    <!-- Binds to List<OrderDTO> -->
                    <DataGrid x:Name="AllOrdersGrid" Grid.Row="2" AutoGenerateColumns="False"
                              IsReadOnly="True" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Order ID"  Binding="{Binding OrderId}"      Width="*"/>
                            <DataGridTextColumn Header="Merchant"  Binding="{Binding MerchantName}" Width="160"/>
                            <DataGridTextColumn Header="Date"      Binding="{Binding OrderDate, StringFormat=\{0:dd/MM/yyyy\}}" Width="90"/>
                            <DataGridTextColumn Header="Total"     Binding="{Binding TotalAmount, StringFormat=£\{0:N2\}}" Width="90"/>
                            <DataGridTextColumn Header="Status"    Binding="{Binding Status}"       Width="100"/>
                            <DataGridTemplateColumn Header="Actions" Width="190">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Update Status" Tag="{Binding}" Click="Order_UpdateStatus" Margin="2" FontSize="10"/>
                                            <Button Content="Dispatch"      Tag="{Binding}" Click="Order_Dispatch"     Margin="2" FontSize="10"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <!-- ══ DISCOUNT PLANS ══ -->
                <Grid x:Name="PanelDiscountPlans" Visibility="Collapsed" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Discount Plans" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>
                    <Button Grid.Row="1" Content="Refresh" HorizontalAlignment="Left"
                            Margin="0,0,0,8" Click="DiscountPlans_Refresh"/>
                    <!-- Binds to List<DiscountPlanDTO> — fields: planId, planName, planType, fixedRate, Summary -->
                    <DataGrid x:Name="DiscountPlansGrid" Grid.Row="2" AutoGenerateColumns="False"
                              IsReadOnly="True" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"      Binding="{Binding PlanId}"   Width="50"/>
                            <DataGridTextColumn Header="Name"    Binding="{Binding PlanName}" Width="*"/>
                            <DataGridTextColumn Header="Type"    Binding="{Binding PlanType}" Width="90"/>
                            <DataGridTextColumn Header="Detail"  Binding="{Binding Summary}"  Width="160"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <!-- Create plan -->
                    <Border Grid.Row="3" Background="White" BorderBrush="#CCC" BorderThickness="1"
                            Padding="12" Margin="0,8,0,0" CornerRadius="4">
                        <StackPanel>
                            <TextBlock Text="Create New Plan" FontWeight="Bold" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <RadioButton x:Name="RadioFixed"    Content="Fixed"    IsChecked="True" Margin="0,0,16,0"/>
                                <RadioButton x:Name="RadioFlexible" Content="Flexible"/>
                            </StackPanel>
                            <!-- Fixed form — planName + fixedRate -->
                            <StackPanel x:Name="FixedPlanForm">
                                <StackPanel Orientation="Horizontal">
                                    <Label Content="Plan Name:" Width="85"/>
                                    <TextBox x:Name="FixedPlanName" Width="160" Margin="0,0,8,0"/>
                                    <Label Content="Rate (%):" Width="70"/>
                                    <TextBox x:Name="FixedPlanRate" Width="60" Margin="0,0,8,0"/>
                                    <Button Content="Create" Click="CreateFixedPlan"/>
                                </StackPanel>
                            </StackPanel>
                            <!-- Flexible form — planName + tiers -->
                            <StackPanel x:Name="FlexiblePlanForm" Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Label Content="Plan Name:" Width="85"/>
                                    <TextBox x:Name="FlexPlanName" Width="200"/>
                                </StackPanel>
                                <TextBlock Text="Tiers — one per line: minOrderVal , maxOrderVal , discountRate"
                                           FontSize="11" Margin="0,4,0,2" Foreground="#555"/>
                                <TextBlock Text="(leave maxOrderVal blank on final tier for open-ended)"
                                           FontSize="10" Margin="0,0,0,4" Foreground="#888"/>
                                <TextBox x:Name="FlexPlanTiers" Height="64" AcceptsReturn="True"
                                         FontFamily="Consolas" FontSize="11" Margin="0,0,0,8"/>
                                <Button Content="Create Flexible Plan" Click="CreateFlexPlan"
                                        HorizontalAlignment="Left"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ══ RECORD PAYMENT ══ -->
                <ScrollViewer x:Name="PanelRecordPayment" Visibility="Collapsed" Margin="20">
                    <StackPanel MaxWidth="480">
                        <TextBlock Text="Record Payment" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>
                        <Label Content="Merchant ID"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBox x:Name="PaymentMerchantId" Width="100" Margin="0,0,8,0"
                                     VerticalContentAlignment="Center"/>
                            <Button Content="Load Invoices" Click="Payment_LoadInvoices"/>
                        </StackPanel>
                        <Label Content="Invoice"/>
                        <!-- DisplayMemberPath set in code-behind to InvoiceId -->
                        <ComboBox x:Name="PaymentInvoiceCombo" Margin="0,0,0,8"/>
                        <Label Content="Amount Paid (£)"/>
                        <TextBox x:Name="PaymentAmount" Margin="0,0,0,8"/>
                        <Label Content="Payment Method"/>
                        <!-- Payment.PaymentMethod: BANK_TRANSFER, CARD, CHEQUE -->
                        <ComboBox x:Name="PaymentMethod" Margin="0,0,0,8">
                            <ComboBoxItem Content="BANK_TRANSFER" IsSelected="True"/>
                            <ComboBoxItem Content="CARD"/>
                            <ComboBoxItem Content="CHEQUE"/>
                        </ComboBox>
                        <Label Content="Payment Date"/>
                        <DatePicker x:Name="PaymentDate" Margin="0,0,0,8"/>
                        <Label Content="Notes (optional)"/>
                        <TextBox x:Name="PaymentNotes" Margin="0,0,0,16"/>
                        <Button Content="Save Payment" Click="Payment_Save"
                                FontWeight="Bold" HorizontalAlignment="Left"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- ══ REPORTS ══ -->
                <Grid x:Name="PanelReports" Visibility="Collapsed" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Reports" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>
                    <Border Grid.Row="1" Background="White" BorderBrush="#CCC" BorderThickness="1"
                            Padding="12" Margin="0,0,0,8" CornerRadius="4">
                        <WrapPanel>
                            <StackPanel Margin="0,0,12,0">
                                <Label Content="Report Type"/>
                                <ComboBox x:Name="ReportType" Width="220">
                                    <ComboBoxItem Content="RPT-01: Turnover"                IsSelected="True"/>
                                    <ComboBoxItem Content="RPT-02: Merchant Orders Summary"/>
                                    <ComboBoxItem Content="RPT-03: Merchant Detailed"/>
                                    <ComboBoxItem Content="RPT-04: Invoice List (Merchant)"/>
                                    <ComboBoxItem Content="RPT-05: All Invoices"/>
                                    <ComboBoxItem Content="RPT-07: Low Stock"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Margin="0,0,12,0">
                                <Label Content="Merchant ID (RPT-02/03/04)"/>
                                <TextBox x:Name="ReportMerchantId" Width="100"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,12,0">
                                <Label Content="From"/>
                                <DatePicker x:Name="ReportFrom"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,12,0">
                                <Label Content="To"/>
                                <DatePicker x:Name="ReportTo"/>
                            </StackPanel>
                            <StackPanel VerticalAlignment="Bottom">
                                <Button Content="Generate" Click="Report_Generate" FontWeight="Bold"/>
                                <Button Content="Print"    Click="Report_Print"    Margin="0,4,0,0"/>
                            </StackPanel>
                        </WrapPanel>
                    </Border>
                    <ScrollViewer Grid.Row="2" Background="White" BorderBrush="#CCC" BorderThickness="1">
                        <TextBox x:Name="ReportOutput" IsReadOnly="True" TextWrapping="Wrap"
                                 AcceptsReturn="True" FontFamily="Consolas" FontSize="11"
                                 BorderThickness="0" Padding="12"/>
                    </ScrollViewer>
                </Grid>

                <!-- ══ AUDIT LOG ══ -->
                <Grid x:Name="PanelAuditLog" Visibility="Collapsed" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Audit Log" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>
                    <WrapPanel Grid.Row="1" Margin="0,0,0,8">
                        <StackPanel Margin="0,0,8,0">
                            <Label Content="User ID"/>
                            <TextBox x:Name="AuditUserId" Width="80"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,8,0">
                            <Label Content="Target Type"/>
                            <TextBox x:Name="AuditTargetType" Width="110"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,8,0">
                            <Label Content="Target ID"/>
                            <TextBox x:Name="AuditTargetId" Width="90"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,8,0">
                            <Label Content="From"/>
                            <DatePicker x:Name="AuditFrom"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,8,0">
                            <Label Content="To"/>
                            <DatePicker x:Name="AuditTo"/>
                        </StackPanel>
                        <StackPanel VerticalAlignment="Bottom">
                            <Button Content="Load" Click="AuditLog_Load"/>
                        </StackPanel>
                    </WrapPanel>
                    <!-- Binds to List<AuditLogDTO> -->
                    <DataGrid x:Name="AuditGrid" Grid.Row="2" AutoGenerateColumns="False"
                              IsReadOnly="True" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time"        Binding="{Binding LoggedAt, StringFormat=\{0:dd/MM/yyyy HH:mm\}}" Width="130"/>
                            <DataGridTextColumn Header="User"        Binding="{Binding Username}"   Width="110"/>
                            <DataGridTextColumn Header="Action"      Binding="{Binding Action}"     Width="160"/>
                            <DataGridTextColumn Header="Target Type" Binding="{Binding TargetType}" Width="110"/>
                            <DataGridTextColumn Header="Target ID"   Binding="{Binding TargetId}"   Width="110"/>
                            <DataGridTextColumn Header="Details"     Binding="{Binding Details}"    Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

            </Grid>
        </Border>
    </Grid>
</Window>

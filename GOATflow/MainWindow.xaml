                VerticalAlignment="Top"
                Data="M24,23.95Q20.7,23.95 18.6,21.85 16.5,19.75 16.5,16.45 16.5,13.15 18.6,11.05 20.7,8.95 24,8.95 27.3,8.95 29.4,11.05 31.5,13.15 31.5,16.45 31.5,19.75 29.4,21.85 27.3,23.95 24,23.95z M11,40Q9.75,40 8.875,39.125 8,38.25 8,37L8,35.3Q8,33.4 8.95,32.05 9.9,30.7 11.4,30 14.75,28.5 17.825,27.75 20.9,27 24,27 27.1,27 30.15,27.775 33.2,28.55 36.55,30 38.1,30.7 39.05,32.05 40,33.4 40,35.3L40,37Q40,38.25 39.125,39.125 38.25,40 37,40z"
                Fill="#FF747474"
                Stretch="Fill" />

        </Grid>
